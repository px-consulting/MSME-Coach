// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl      = env("DIRECT_URL")

}

// User model 
model User {
  id          String  @id @default(uuid())
  clerkUserId String  @unique
  email       String  @unique
  name        String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  businessInsight  BusinessInsight?
  assessments       Assessment[]
  fundingReadiness  FundingReadiness?
  businessPlans     BusinessPlan[]
}

// Business Information 
model BusinessInsight {
  id              String @id @default(uuid())
  userId          String @unique
  user            User   @relation(fields: [userId], references: [id])
  businessName    String
  industry        String
  subSegment      String
  businessModel   String
  customerType    String
  annualRevenue   String
  employeeCount   Int
  topProducts     String[]
  marketType      String
  businessChallenges String[]
  desirability      Json? 
  feasibility       Json? 
  viability         Json? 
}

// Business Assessment (360 Degree)
model Assessment {
  id              String @id @default(uuid())
  userId          String
  user            User   @relation(fields: [userId], references: [id])
  score           Float
  answers         Json
  maturityLevel   String
  report          String
  dateTaken       DateTime @default(now())
}

// Funding Readiness
model FundingReadiness {
  id              String @id @default(uuid())
  userId          String @unique
  user            User   @relation(fields: [userId], references: [id])
  score           Int
  scoreDetails    Json
  readinessLevel  String // Ready, Near-Ready, Moderate, Not Ready
  issuedAt        DateTime @default(now())
}

// Business Plan Generator
model BusinessPlan {
  id              String @id @default(uuid())
  userId          String
  user            User   @relation(fields: [userId], references: [id])
  title           String
  content         String // Business plan text or JSON format
  createdAt       DateTime @default(now())
}


